//@version=6
// =====================================================================================
// Hermes BTC Pulse Composite v7 IndexTrend — tuned for Grok-Bot-2 / Hermes pulse engine
// =====================================================================================
// INDEX:BTCUSD only — aligns with Chainlink BTC/USD settlement (no Binance BTCUSDT).
//   TradingView BTC Index = avg(BITSTAMP, COINBASE, BITFINEX, KRAKEN) spot USD.
//   USAGE: same script on FOUR charts — all INDEX:BTCUSD:
//     1m, 5m, 10m, 15m — one alert per chart (Any alert() function call).
//     Bot builds 4-TF price trend via mtf_confirmation (1/5/10/15).
//   Webhook → http://<vps-ip>/webhooks/tradingview
// =====================================================================================
indicator("Hermes BTC Pulse Composite v7 IndexTrend", overlay=true, max_labels_count=500)

// =====================================================
// Hermes settings
// =====================================================
secretInput = input.string("21b5b67ad74c5ad9d972bc5d90916c7a636767e7366a6d7d", "Hermes webhook secret")
botName = input.string("hermes", "Bot name")
indicatorName = input.string("Hermes BTC Pulse Composite v7 IndexTrend", "Indicator name")
compositeVersion = "v7"

sendWeakSignals = input.bool(true, "Send weak signals")
sendStrongSignals = input.bool(true, "Send strong signals")

// MORE SELECTIVE than v4 (was 4/7/1): a TV confirmation should mean something to the bot.
weakScoreMin = input.int(5, "Weak signal minimum score", minval=1, maxval=20)
strongScoreMin = input.int(8, "Strong signal minimum score", minval=1, maxval=20)
scoreGapMin = input.int(2, "Minimum score gap", minval=0, maxval=10)

// Manual observe-only macro/crowding inputs.
manualFundingState = input.string("neutral", "Funding state", options=["neutral", "long_crowded", "short_crowded", "unknown"])
manualEventBlackout = input.bool(false, "Event blackout next 10 minutes")

// =====================================================
// JSON helpers
// =====================================================
jsonNum(x) =>
    na(x) ? "null" : str.tostring(x)

jsonBool(x) =>
    x ? "true" : "false"

// =====================================================
// EMA trend filter
// =====================================================
emaFastLen = input.int(9, "EMA fast length", minval=1)
emaMidLen = input.int(21, "EMA mid length", minval=1)
emaSlowLen = input.int(50, "EMA slow length", minval=1)

emaFast = ta.ema(close, emaFastLen)
emaMid = ta.ema(close, emaMidLen)
emaSlow = ta.ema(close, emaSlowLen)

trendUp = emaFast > emaMid and close > emaMid
trendDown = emaFast < emaMid and close < emaMid

strongTrendUp = emaFast > emaMid and emaMid > emaSlow and close > emaMid
strongTrendDown = emaFast < emaMid and emaMid < emaSlow and close < emaMid

// =====================================================
// RSI divergence
// =====================================================
rsiLen = input.int(14, "RSI length", minval=2)
pivotLeft = input.int(3, "Divergence pivot left", minval=1)
pivotRight = input.int(3, "Divergence pivot right", minval=1)

rsi = ta.rsi(close, rsiLen)

pricePivotLow = ta.pivotlow(low, pivotLeft, pivotRight)
rsiPivotLow = ta.pivotlow(rsi, pivotLeft, pivotRight)

pricePivotHigh = ta.pivothigh(high, pivotLeft, pivotRight)
rsiPivotHigh = ta.pivothigh(rsi, pivotLeft, pivotRight)

prevPricePivotLow = ta.valuewhen(not na(pricePivotLow), pricePivotLow, 1)
prevRsiPivotLow = ta.valuewhen(not na(rsiPivotLow), rsiPivotLow, 1)

prevPricePivotHigh = ta.valuewhen(not na(pricePivotHigh), pricePivotHigh, 1)
prevRsiPivotHigh = ta.valuewhen(not na(rsiPivotHigh), rsiPivotHigh, 1)

bullishDiv = not na(pricePivotLow) and not na(rsiPivotLow) and not na(prevPricePivotLow) and not na(prevRsiPivotLow) and pricePivotLow < prevPricePivotLow and rsiPivotLow > prevRsiPivotLow
bearishDiv = not na(pricePivotHigh) and not na(rsiPivotHigh) and not na(prevPricePivotHigh) and not na(prevRsiPivotHigh) and pricePivotHigh > prevPricePivotHigh and rsiPivotHigh < prevRsiPivotHigh

// =====================================================
// Momentum confirmation
// =====================================================
rocLen = input.int(3, "ROC length", minval=1)
roc = ta.roc(close, rocLen)

momentumUp = rsi > 50 and roc > 0
momentumDown = rsi < 50 and roc < 0

softMomentumUp = rsi > 48 or roc > 0
softMomentumDown = rsi < 52 or roc < 0

// =====================================================
// ATR volatility filter
// =====================================================
atrLen = input.int(14, "ATR length", minval=1)
atrAvgLen = input.int(50, "ATR average length", minval=2)
atrMinRatio = input.float(0.55, "Minimum ATR activity ratio", minval=0.1, step=0.05)
atrMaxRatio = input.float(3.50, "Maximum ATR danger ratio", minval=0.5, step=0.05)

atr = ta.atr(atrLen)
atrAvg = ta.sma(atr, atrAvgLen)
atrRatio = atrAvg > 0 ? atr / atrAvg : na

atrActive = na(atrRatio) ? true : atrRatio >= atrMinRatio and atrRatio <= atrMaxRatio

// =====================================================
// VWAP state
// =====================================================
useVwapFilter = input.bool(true, "Use VWAP filter")
vwapValue = ta.vwap(hlc3)

vwapState = na(vwapValue) ? "unknown" :
     ta.crossover(close, vwapValue) ? "reclaim" :
     ta.crossunder(close, vwapValue) ? "reject" :
     close > vwapValue ? "above" :
     close < vwapValue ? "below" : "unknown"

vwapBull = vwapState == "above" or vwapState == "reclaim" or vwapState == "unknown"
vwapBear = vwapState == "below" or vwapState == "reject" or vwapState == "unknown"

// =====================================================
// Bollinger squeeze and expansion
// =====================================================
bbLen = input.int(20, "Bollinger length", minval=2)
bbMult = input.float(2.0, "Bollinger multiplier", minval=0.1, step=0.1)
bbAvgLen = input.int(50, "Bollinger width average length", minval=2)

bbBasis = ta.sma(close, bbLen)
bbDev = bbMult * ta.stdev(close, bbLen)
bbUpper = bbBasis + bbDev
bbLower = bbBasis - bbDev
bbWidth = bbBasis != 0 ? (bbUpper - bbLower) / bbBasis : na
bbWidthAvg = ta.sma(bbWidth, bbAvgLen)

bbSqueeze = not na(bbWidth) and not na(bbWidthAvg) and bbWidth < bbWidthAvg * 0.80
bbExpanding = not na(bbWidth) and not na(bbWidthAvg) and bbWidth > bbWidth[1]

bbState = na(bbWidth) or na(bbWidthAvg) ? "unknown" :
     bbSqueeze ? "squeeze" :
     bbExpanding and close > bbBasis ? "expansion_up" :
     bbExpanding and close < bbBasis ? "expansion_down" :
     "normal"

// =====================================================
// INDEX bar-range activity (INDEX has no exchange volume)
// =====================================================
useVolumeFilter = input.bool(true, "Use bar-range activity filter")
suppressVolumeSpikes = input.bool(true, "Suppress activity spike bars (profit gate)")
volAvgLen = input.int(50, "Range activity average length", minval=2)
volSpikeRatio = input.float(1.35, "Activity spike ratio", minval=0.1, step=0.05)
volActiveRatio = input.float(0.80, "Activity active ratio", minval=0.1, step=0.05)
volDeadRatio = input.float(0.50, "Activity dead ratio", minval=0.1, step=0.05)

barRange = high - low
avgBarRange = ta.sma(barRange, volAvgLen)
relativeVolume = avgBarRange > 0 ? barRange / avgBarRange : na

volumeState = na(relativeVolume) ? "unknown" :
     relativeVolume >= volSpikeRatio ? "spike" :
     relativeVolume >= volActiveRatio ? "active" :
     relativeVolume <= volDeadRatio ? "dead" :
     "active"

volumePassesFilter = not useVolumeFilter or volumeState == "active" or volumeState == "dead" or volumeState == "unknown"
volumeNotSpike = not suppressVolumeSpikes or volumeState != "spike"
volumeOk = volumePassesFilter and volumeNotSpike

// =====================================================
// Observe-only price-pressure proxy (INDEX chart)
// =====================================================
cvdLookback = input.int(20, "Price pressure lookback", minval=3)
cvdPressureThreshold = input.float(0.12, "Price pressure threshold", minval=0.01, step=0.01)

signedMove = close - open
cvdDeltaAvg = ta.sma(signedMove, cvdLookback)
cvdVolAvg = ta.sma(math.abs(close - open), cvdLookback)
cvdRatio = cvdVolAvg > 0 ? cvdDeltaAvg / cvdVolAvg : na

cvdState = na(cvdRatio) ? "unknown" :
     cvdRatio > cvdPressureThreshold ? "buy_pressure" :
     cvdRatio < -cvdPressureThreshold ? "sell_pressure" :
     "neutral"

// =====================================================
// 15m higher-timeframe EMA bias
// =====================================================
useHtfBias = input.bool(true, "Use 15m EMA bias")
htfTf = input.timeframe("15", "Higher-timeframe bias timeframe")

htfEmaFast = request.security(syminfo.tickerid, htfTf, ta.ema(close, 9), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfEmaMid = request.security(syminfo.tickerid, htfTf, ta.ema(close, 21), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

htfBias = na(htfEmaFast) or na(htfEmaMid) ? "unknown" :
     htfEmaFast > htfEmaMid ? "bullish" :
     htfEmaFast < htfEmaMid ? "bearish" :
     "neutral"

// =====================================================
// ADX trend strength
// =====================================================
useAdxFilter = input.bool(true, "Use ADX trend strength filter")
adxLen = input.int(14, "ADX DI length", minval=2)
adxSmooth = input.int(14, "ADX smoothing", minval=2)
adxWeakMax = input.float(15.0, "ADX weak below", minval=1.0, step=0.5)
adxStrongMin = input.float(22.0, "ADX strong above", minval=1.0, step=0.5)

[plusDI, minusDI, adx] = ta.dmi(adxLen, adxSmooth)

adxState = na(adx) ? "unknown" :
     adx >= adxStrongMin ? "strong_trend" :
     adx < adxWeakMax ? "weak_trend" :
     "normal_trend"

adxOk = not useAdxFilter or adxState == "strong_trend" or adxState == "normal_trend" or adxState == "unknown"

// =====================================================
// SuperTrend regime
// =====================================================
useSuperTrendFilter = input.bool(true, "Use SuperTrend filter")
superTrendAtrLen = input.int(10, "SuperTrend ATR length", minval=1)
superTrendFactor = input.float(3.0, "SuperTrend factor", minval=0.1, step=0.1)

[superTrendValue, superTrendDirectionRaw] = ta.supertrend(superTrendFactor, superTrendAtrLen)

superTrendDirection = na(superTrendDirectionRaw) ? "unknown" :
     superTrendDirectionRaw < 0 ? "bullish" :
     superTrendDirectionRaw > 0 ? "bearish" :
     "neutral"

superTrendAligned = (superTrendDirection == "bullish" and trendUp) or (superTrendDirection == "bearish" and trendDown)

// =====================================================
// Candle pressure, wick rejection, liquidation proxy
// =====================================================
useCandlePressureFilter = input.bool(true, "Use candle pressure filter")
liqVolRatio = input.float(1.60, "Liquidation proxy volume ratio", minval=0.5, step=0.05)
liqWickRatio = input.float(0.45, "Liquidation proxy wick ratio", minval=0.1, step=0.05)

candleRange = high - low
candleBody = math.abs(close - open)
upperWick = high - math.max(open, close)
lowerWick = math.min(open, close) - low

bodyRatio = candleRange > 0 ? candleBody / candleRange : na
closePosition = candleRange > 0 ? (close - low) / candleRange : na
upperWickRatio = candleRange > 0 ? upperWick / candleRange : na
lowerWickRatio = candleRange > 0 ? lowerWick / candleRange : na

candlePressure = na(closePosition) or na(bodyRatio) ? "unknown" :
     close > open and closePosition >= 0.65 ? "bull_close_near_high" :
     close < open and closePosition <= 0.35 ? "bear_close_near_low" :
     upperWickRatio >= 0.45 and closePosition <= 0.50 ? "upper_wick_rejection" :
     lowerWickRatio >= 0.45 and closePosition >= 0.50 ? "lower_wick_rejection" :
     "neutral_candle"

liqUpper = not na(relativeVolume) and not na(upperWickRatio) and relativeVolume >= liqVolRatio and upperWickRatio >= liqWickRatio
liqLower = not na(relativeVolume) and not na(lowerWickRatio) and relativeVolume >= liqVolRatio and lowerWickRatio >= liqWickRatio

liquidationSpike = liqUpper or liqLower

liquidationSide = liqUpper and liqLower ? "mixed" :
     liqUpper ? "short_liquidation" :
     liqLower ? "long_liquidation" :
     liquidationSpike ? "mixed" :
     "none"

// =====================================================
// Range breakout and structural levels
// =====================================================
useRangeFilter = input.bool(false, "Use range breakout filter")
rangeLookback = input.int(10, "Range breakout lookback", minval=2)

priorRangeHigh = ta.highest(high[1], rangeLookback)
priorRangeLow = ta.lowest(low[1], rangeLookback)
priorRangeSize = priorRangeHigh - priorRangeLow
rangePosition = priorRangeSize > 0 ? (close - priorRangeLow) / priorRangeSize : na

rangeState = na(rangePosition) or na(priorRangeHigh) or na(priorRangeLow) ? "unknown" :
     close > priorRangeHigh ? "breakout_up" :
     close < priorRangeLow ? "breakout_down" :
     rangePosition >= 0.70 ? "range_top" :
     rangePosition <= 0.30 ? "range_bottom" :
     "range_middle"

lastSupport = ta.valuewhen(not na(pricePivotLow), pricePivotLow, 0)
lastResistance = ta.valuewhen(not na(pricePivotHigh), pricePivotHigh, 0)

priorDayHigh = request.security(syminfo.tickerid, "D", high[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
priorDayLow = request.security(syminfo.tickerid, "D", low[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

distSupport = not na(lastSupport) and close != 0 ? math.abs(close - lastSupport) / close : na
distResistance = not na(lastResistance) and close != 0 ? math.abs(close - lastResistance) / close : na
distPriorHigh = not na(priorDayHigh) and close != 0 ? math.abs(close - priorDayHigh) / close : na
distPriorLow = not na(priorDayLow) and close != 0 ? math.abs(close - priorDayLow) / close : na
distVwap = not na(vwapValue) and close != 0 ? math.abs(close - vwapValue) / close : na

float nearestDistTmp = 1000000000.0
string nearestTypeTmp = "unknown"

if not na(distSupport) and distSupport < nearestDistTmp
    nearestDistTmp := distSupport
    nearestTypeTmp := "support"

if not na(distResistance) and distResistance < nearestDistTmp
    nearestDistTmp := distResistance
    nearestTypeTmp := "resistance"

if not na(distPriorHigh) and distPriorHigh < nearestDistTmp
    nearestDistTmp := distPriorHigh
    nearestTypeTmp := "prior_day_high"

if not na(distPriorLow) and distPriorLow < nearestDistTmp
    nearestDistTmp := distPriorLow
    nearestTypeTmp := "prior_day_low"

if not na(distVwap) and distVwap < nearestDistTmp
    nearestDistTmp := distVwap
    nearestTypeTmp := "vwap"

distToLevel = nearestTypeTmp == "unknown" ? na : nearestDistTmp
nearestLevelType = nearestTypeTmp

// =====================================================
// Multi-timeframe alignment
// =====================================================
mtfAlignment = trendUp and htfBias == "bullish" ? "bullish_aligned" :
     trendDown and htfBias == "bearish" ? "bearish_aligned" :
     (trendUp and htfBias == "bearish") or (trendDown and htfBias == "bullish") ? "mixed" :
     trendUp or trendDown ? "neutral" :
     "unknown"

// =====================================================
// Loose score system
// =====================================================
int upScore = 0
int downScore = 0

upScore := upScore + (bullishDiv ? 2 : 0)
downScore := downScore + (bearishDiv ? 2 : 0)

upScore := upScore + (strongTrendUp ? 2 : trendUp ? 1 : 0)
downScore := downScore + (strongTrendDown ? 2 : trendDown ? 1 : 0)

upScore := upScore + (momentumUp ? 2 : softMomentumUp ? 1 : 0)
downScore := downScore + (momentumDown ? 2 : softMomentumDown ? 1 : 0)

upScore := upScore + (vwapBull ? 1 : 0)
downScore := downScore + (vwapBear ? 1 : 0)

upScore := upScore + (bbState == "expansion_up" ? 1 : 0)
downScore := downScore + (bbState == "expansion_down" ? 1 : 0)

upScore := upScore + (htfBias == "bullish" ? 1 : 0)
downScore := downScore + (htfBias == "bearish" ? 1 : 0)

upScore := upScore + (plusDI > minusDI and adxState != "weak_trend" ? 1 : 0)
downScore := downScore + (minusDI > plusDI and adxState != "weak_trend" ? 1 : 0)

upScore := upScore + (superTrendDirection == "bullish" ? 1 : 0)
downScore := downScore + (superTrendDirection == "bearish" ? 1 : 0)

upScore := upScore + (candlePressure == "bull_close_near_high" or candlePressure == "lower_wick_rejection" ? 1 : 0)
downScore := downScore + (candlePressure == "bear_close_near_low" or candlePressure == "upper_wick_rejection" ? 1 : 0)

upScore := upScore + (rangeState == "breakout_up" or rangeState == "range_top" ? 1 : 0)
downScore := downScore + (rangeState == "breakout_down" or rangeState == "range_bottom" ? 1 : 0)

upScore := upScore + (mtfAlignment == "bullish_aligned" ? 1 : 0)
downScore := downScore + (mtfAlignment == "bearish_aligned" ? 1 : 0)

upScore := upScore + (cvdState == "buy_pressure" ? 1 : 0)
downScore := downScore + (cvdState == "sell_pressure" ? 1 : 0)

upScore := upScore + (manualFundingState == "short_crowded" ? 1 : 0)
downScore := downScore + (manualFundingState == "long_crowded" ? 1 : 0)

// max attainable single-side score (div2 + trend2 + momentum2 + 11 one-point components)
maxScore = 16

eventOk = not manualEventBlackout

candleOkUp = not useCandlePressureFilter or (candlePressure != "upper_wick_rejection" and not liqUpper)
candleOkDown = not useCandlePressureFilter or (candlePressure != "lower_wick_rejection" and not liqLower)

stOkUp = not useSuperTrendFilter or superTrendDirection == "bullish"
stOkDown = not useSuperTrendFilter or superTrendDirection == "bearish"

baseOk = atrActive and volumeOk and adxOk and eventOk

upWins = upScore >= weakScoreMin and upScore > downScore + scoreGapMin - 1 and baseOk and stOkUp and candleOkUp
downWins = downScore >= weakScoreMin and downScore > upScore + scoreGapMin - 1 and baseOk and stOkDown and candleOkDown

fireUpStrong = sendStrongSignals and upWins and upScore >= strongScoreMin
fireDownStrong = sendStrongSignals and downWins and downScore >= strongScoreMin

fireUpWeak = sendWeakSignals and upWins and not fireUpStrong
fireDownWeak = sendWeakSignals and downWins and not fireDownStrong

signalDirection = fireUpStrong ? "UP" :
     fireDownStrong ? "DOWN" :
     fireUpWeak ? "UP" :
     fireDownWeak ? "DOWN" :
     "NONE"

signalLevel = fireUpStrong ? "UP_STRONG" :
     fireDownStrong ? "DOWN_STRONG" :
     fireUpWeak ? "UP_WEAK" :
     fireDownWeak ? "DOWN_WEAK" :
     "NONE"

activeScore = signalDirection == "UP" ? upScore : signalDirection == "DOWN" ? downScore : 0
// CONTINUOUS, CALIBRATED strength (v5): normalized conviction mapped to ~0.4..1.0 so the bot's
// tv_strength_thr gate is meaningful and Grok sees graded conviction (was: flat 0.58/0.82).
scoreRatio = activeScore / maxScore
signalStrength = signalDirection == "NONE" ? 0.0 : math.round((0.40 + 0.60 * scoreRatio) * 100) / 100

signalAgeMs = timenow - time_close
shouldAlert = barstate.isconfirmed and signalDirection != "NONE"

// =====================================================
// Dynamic Hermes JSON webhook alert (field set unchanged + additive: score_ratio, max_score)
// =====================================================
if shouldAlert
    eventId = syminfo.ticker + "-" + timeframe.period + "-" + str.tostring(time) + "-" + signalLevel + "-v7-indextrend"

    msg = "{"
    msg := msg + "\"secret\":\"" + secretInput + "\","
    msg := msg + "\"bot_name\":\"" + botName + "\","
    msg := msg + "\"source\":\"tradingview\","
    msg := msg + "\"symbol\":\"INDEX:BTCUSD\","
    msg := msg + "\"tickerid\":\"" + syminfo.tickerid + "\","
    msg := msg + "\"timeframe\":\"" + timeframe.period + "\","
    msg := msg + "\"direction\":\"" + signalDirection + "\","
    msg := msg + "\"signal_level\":\"" + signalLevel + "\","
    msg := msg + "\"strength\":" + str.tostring(signalStrength) + ","
    msg := msg + "\"score_ratio\":" + str.tostring(math.round(scoreRatio * 1000) / 1000) + ","
    msg := msg + "\"max_score\":" + str.tostring(maxScore) + ","
    msg := msg + "\"indicator_name\":\"" + indicatorName + "\","
    msg := msg + "\"event_id\":\"" + eventId + "\","
    msg := msg + "\"bar_time\":\"" + str.tostring(time_close) + "\","
    msg := msg + "\"fired_at\":\"" + str.tostring(timenow) + "\","
    msg := msg + "\"price\":" + jsonNum(close) + ","
    msg := msg + "\"rsi\":" + jsonNum(rsi) + ","
    msg := msg + "\"roc\":" + jsonNum(roc) + ","
    msg := msg + "\"ema_fast\":" + jsonNum(emaFast) + ","
    msg := msg + "\"ema_mid\":" + jsonNum(emaMid) + ","
    msg := msg + "\"ema_slow\":" + jsonNum(emaSlow) + ","
    msg := msg + "\"trend_up\":" + jsonBool(trendUp) + ","
    msg := msg + "\"trend_down\":" + jsonBool(trendDown) + ","
    msg := msg + "\"momentum_up\":" + jsonBool(momentumUp) + ","
    msg := msg + "\"momentum_down\":" + jsonBool(momentumDown) + ","
    msg := msg + "\"bullish_divergence\":" + jsonBool(bullishDiv) + ","
    msg := msg + "\"bearish_divergence\":" + jsonBool(bearishDiv) + ","
    msg := msg + "\"atr\":" + jsonNum(atr) + ","
    msg := msg + "\"atr_ratio\":" + jsonNum(atrRatio) + ","
    msg := msg + "\"atr_active\":" + jsonBool(atrActive) + ","
    msg := msg + "\"index_symbol\":\"INDEX:BTCUSD\","
    msg := msg + "\"chart_timeframe\":\"" + timeframe.period + "\","
    msg := msg + "\"trend_up\":" + jsonBool(trendUp) + ","
    msg := msg + "\"trend_down\":" + jsonBool(trendDown) + ","
    msg := msg + "\"vwap\":" + jsonNum(vwapValue) + ","
    msg := msg + "\"vwap_state\":\"" + vwapState + "\","
    msg := msg + "\"bb_width\":" + jsonNum(bbWidth) + ","
    msg := msg + "\"bb_state\":\"" + bbState + "\","
    msg := msg + "\"relative_volume\":" + jsonNum(relativeVolume) + ","
    msg := msg + "\"volume_state\":\"" + volumeState + "\","
    msg := msg + "\"htf_bias\":\"" + htfBias + "\","
    msg := msg + "\"adx\":" + jsonNum(adx) + ","
    msg := msg + "\"adx_state\":\"" + adxState + "\","
    msg := msg + "\"supertrend_value\":" + jsonNum(superTrendValue) + ","
    msg := msg + "\"supertrend_direction\":\"" + superTrendDirection + "\","
    msg := msg + "\"supertrend_aligned\":" + jsonBool(superTrendAligned) + ","
    msg := msg + "\"candle_pressure\":\"" + candlePressure + "\","
    msg := msg + "\"body_ratio\":" + jsonNum(bodyRatio) + ","
    msg := msg + "\"close_position\":" + jsonNum(closePosition) + ","
    msg := msg + "\"upper_wick_ratio\":" + jsonNum(upperWickRatio) + ","
    msg := msg + "\"lower_wick_ratio\":" + jsonNum(lowerWickRatio) + ","
    msg := msg + "\"range_state\":\"" + rangeState + "\","
    msg := msg + "\"range_lookback\":" + str.tostring(rangeLookback) + ","
    msg := msg + "\"prior_range_high\":" + jsonNum(priorRangeHigh) + ","
    msg := msg + "\"prior_range_low\":" + jsonNum(priorRangeLow) + ","
    msg := msg + "\"mtf_alignment\":\"" + mtfAlignment + "\","
    msg := msg + "\"up_score\":" + str.tostring(upScore) + ","
    msg := msg + "\"down_score\":" + str.tostring(downScore) + ","
    msg := msg + "\"active_score\":" + str.tostring(activeScore) + ","
    msg := msg + "\"cvd_state\":\"" + cvdState + "\","
    msg := msg + "\"funding_state\":\"" + manualFundingState + "\","
    msg := msg + "\"liquidation_spike\":" + jsonBool(liquidationSpike) + ","
    msg := msg + "\"liquidation_side\":\"" + liquidationSide + "\","
    msg := msg + "\"event_blackout\":" + jsonBool(manualEventBlackout) + ","
    msg := msg + "\"dist_to_level\":" + jsonNum(distToLevel) + ","
    msg := msg + "\"nearest_level_type\":\"" + nearestLevelType + "\","
    msg := msg + "\"prior_day_high\":" + jsonNum(priorDayHigh) + ","
    msg := msg + "\"prior_day_low\":" + jsonNum(priorDayLow) + ","
    msg := msg + "\"bar_confirmed\":" + jsonBool(barstate.isconfirmed) + ","
    msg := msg + "\"signal_age_ms\":" + str.tostring(signalAgeMs) + ","
    msg := msg + "\"non_repainting\":true,"
    msg := msg + "\"composite_version\":\"" + compositeVersion + "\","
    msg := msg + "\"observe_only\":true"
    msg := msg + "}"

    alert(msg, alert.freq_once_per_bar_close)

// =====================================================
// Visual plots
// =====================================================
plot(emaFast, "EMA Fast", color=color.new(color.green, 0))
plot(emaMid, "EMA Mid", color=color.new(color.orange, 0))
plot(emaSlow, "EMA Slow", color=color.new(color.red, 0))
plot(vwapValue, "VWAP", color=color.new(color.blue, 0))

plot(bbUpper, "BB Upper", color=color.new(color.gray, 75))
plot(bbLower, "BB Lower", color=color.new(color.gray, 75))

plot(superTrendValue, "SuperTrend", color=superTrendDirection == "bullish" ? color.new(color.lime, 0) : color.new(color.red, 0))

plotshape(fireUpStrong, title="UP STRONG", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.small, text="UP+")
plotshape(fireDownStrong, title="DOWN STRONG", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, text="DN+")

plotshape(fireUpWeak, title="UP WEAK", style=shape.circle, location=location.belowbar, color=color.new(color.lime, 45), size=size.tiny, text="UP")
plotshape(fireDownWeak, title="DOWN WEAK", style=shape.circle, location=location.abovebar, color=color.new(color.red, 45), size=size.tiny, text="DN")

bgcolor(atrActive ? na : color.new(color.gray, 88), title="ATR inactive background")
