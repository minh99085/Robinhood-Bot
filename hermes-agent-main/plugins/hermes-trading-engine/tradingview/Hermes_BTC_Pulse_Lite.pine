//@version=6
// =====================================================================================
// Hermes BTC Pulse Lite — simple 3-chart MTF (observe-only webhooks; Bot1 + Bot2 dual-feed)
// =====================================================================================
// Symbol: BTCUSD (or INDEX:BTCUSD — bot normalizes both to BTCUSD).
//
// SETUP (minimum 3 alerts):
//   1. Open THREE charts, same symbol BTCUSD (or INDEX:BTCUSD):
//        • 2 minute
//        • 3 minute
//        • 4 minute
//   2. Add this indicator to each chart.
//   3. Create ONE alert per chart:
//        Condition: "Any alert() function call"
//        Webhook URL: http://<your-vps-ip>/webhooks/tradingview
//        Message: leave default (script builds JSON in alert())
//
// Each chart sends a lightweight row: direction, strength, signal_level, timeframe.
// Optional FLAT heartbeat on quiet bars keeps per-TF ages fresh (see sendFlatHeartbeat).
// Bot MTF config: PULSE_TV_MTF_TIMEFRAMES=2,3,4
// =====================================================================================
indicator("Hermes BTC Pulse Lite", overlay=true)

// --- Hermes webhook (paste secret from VPS .env TRADINGVIEW_WEBHOOK_SECRET) ---
secretInput = input.string("", "Hermes webhook secret")
botName = input.string("hermes", "Bot name")
eventIdSuffix = input.string("bot2", "Event ID suffix (bot1/bot2 — required for dual-bot alerts)")
indicatorName = input.string("Hermes BTC Pulse Lite", "Indicator name")
liteVersion = "lite-2"

sendWeak = input.bool(true, "Send weak signals")
sendStrong = input.bool(true, "Send strong signals")
sendFlatHeartbeat = input.bool(true, "Send FLAT on quiet bars (keeps MTF age fresh)")

// --- Simple trend: dual EMA + RSI ---
emaFastLen = input.int(9, "EMA fast", minval=2)
emaSlowLen = input.int(21, "EMA slow", minval=5)
emaTrendLen = input.int(50, "EMA trend filter", minval=10)
rsiLen = input.int(14, "RSI length", minval=2)

emaFast = ta.ema(close, emaFastLen)
emaSlow = ta.ema(close, emaSlowLen)
emaTrend = ta.ema(close, emaTrendLen)
rsi = ta.rsi(close, rsiLen)

// Basic direction
bullBase = emaFast > emaSlow and close > emaSlow and rsi > 50
bearBase = emaFast < emaSlow and close < emaSlow and rsi < 50

// Strong = aligned with slower trend + RSI push
bullStrong = bullBase and emaSlow > emaTrend and rsi >= 55
bearStrong = bearBase and emaSlow < emaTrend and rsi <= 45

bullWeak = bullBase and not bullStrong
bearWeak = bearBase and not bearStrong

fireUpStrong = sendStrong and bullStrong
fireUpWeak = sendWeak and bullWeak and not fireUpStrong
fireDownStrong = sendStrong and bearStrong
fireDownWeak = sendWeak and bearWeak and not fireDownStrong

signalDirection = fireUpStrong or fireUpWeak ? "UP" :
     fireDownStrong or fireDownWeak ? "DOWN" : "NONE"

signalLevel = fireUpStrong ? "UP_STRONG" :
     fireDownStrong ? "DOWN_STRONG" :
     fireUpWeak ? "UP_WEAK" :
     fireDownWeak ? "DOWN_WEAK" : "NONE"

// Strength 0.40–0.90 from RSI distance from 50 (simple, calibrated)
rsiPush = math.abs(rsi - 50) / 50
signalStrength = signalDirection == "NONE" ? 0.0 :
     signalLevel == "UP_STRONG" or signalLevel == "DOWN_STRONG" ?
         math.round((0.65 + 0.25 * math.min(rsiPush, 1.0)) * 100) / 100 :
         math.round((0.40 + 0.25 * math.min(rsiPush, 1.0)) * 100) / 100

hasSignal = signalDirection != "NONE"
shouldAlert = barstate.isconfirmed and (hasSignal or sendFlatHeartbeat)

// --- Minimal JSON (lightweight TF row + required auth fields) ---
if shouldAlert
    outDir = hasSignal ? signalDirection : "FLAT"
    outLevel = hasSignal ? signalLevel : "FLAT"
    outStrength = hasSignal ? signalStrength : 0.0

    idTag = eventIdSuffix != "" ? "-" + eventIdSuffix : ""
    eventId = "BTCUSD-" + timeframe.period + "-" + str.tostring(time_close) + "-" + outLevel + "-" + liteVersion + idTag

    msg = "{"
    msg := msg + "\"secret\":\"" + secretInput + "\","
    msg := msg + "\"bot_name\":\"" + botName + "\","
    msg := msg + "\"source\":\"tradingview\","
    msg := msg + "\"symbol\":\"BTCUSD\","
    msg := msg + "\"timeframe\":\"" + timeframe.period + "\","
    msg := msg + "\"direction\":\"" + outDir + "\","
    msg := msg + "\"signal_level\":\"" + outLevel + "\","
    msg := msg + "\"strength\":" + str.tostring(outStrength) + ","
    msg := msg + "\"indicator_name\":\"" + indicatorName + "\","
    msg := msg + "\"event_id\":\"" + eventId + "\","
    msg := msg + "\"bar_time\":\"" + str.tostring(time_close) + "\","
    msg := msg + "\"price\":" + str.tostring(close, format.mintick) + ","
    msg := msg + "\"composite_version\":\"" + liteVersion + "\","
    msg := msg + "\"bar_confirmed\":true,"
    msg := msg + "\"non_repainting\":true"
    msg := msg + "}"

    alert(msg, alert.freq_once_per_bar_close)

// --- Optional on-chart context ---
plot(emaFast, "EMA fast", color=color.new(color.teal, 0), linewidth=1)
plot(emaSlow, "EMA slow", color=color.new(color.orange, 0), linewidth=2)
plot(emaTrend, "EMA trend", color=color.new(color.gray, 40), linewidth=1)

bgcolor(bullStrong ? color.new(color.green, 92) :
     bearStrong ? color.new(color.red, 92) :
     bullWeak ? color.new(color.green, 96) :
     bearWeak ? color.new(color.red, 96) : na)

plotshape(fireUpStrong, title="UP strong", style=shape.triangleup, location=location.belowbar,
     color=color.green, size=size.tiny, text="UP+")
plotshape(fireDownStrong, title="DOWN strong", style=shape.triangledown, location=location.abovebar,
     color=color.red, size=size.tiny, text="DN+")