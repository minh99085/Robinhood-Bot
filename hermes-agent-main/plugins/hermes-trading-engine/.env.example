# Copy this file to ".env" (same folder) and fill in your key to enable Grok.
#
#   1. Go to  https://console.x.ai   (this is the DEVELOPER API console).
#      NOTE: a SuperGrok / X Premium subscription is NOT the same thing and
#      does NOT work here — the API needs its own free signup + credits.
#   2. Create an API key (starts with "xai-").
#   3. Paste it below, save the file as ".env", then run: docker compose up
#
# Leave this unset to run the engine on pure quant signals (no LLM brain).

XAI_API_KEY=

# Optional: which Grok model to use. If this name isn't available on your
# account, the engine automatically asks your account for its model list and
# picks the best available Grok model — so you can usually leave this as-is.
HTE_GROK_MODEL=grok-4.3

# ===========================================================================
# Phase 6 — venue-neutral layer + Kalshi READ-ONLY market data
# ===========================================================================
# Kalshi integration is READ-ONLY: market data + metadata only. There is NO
# order placement, NO cancellation, and NO private user (fills/orders/positions)
# subscriptions. Read-only auth signs ONLY GET requests + the WS handshake.
# Missing credentials degrade gracefully (Kalshi disabled; Polymarket still works).
# Keys are never logged, persisted, displayed, sent to Grok, or put in replay
# artifacts. Prefer KALSHI_PRIVATE_KEY_PATH (a file) over inlining the PEM.
KALSHI_ENABLED=0
KALSHI_ENV=demo
KALSHI_REST_BASE_URL=
KALSHI_WS_URL=
KALSHI_ACCESS_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_PRIVATE_KEY_PEM=
KALSHI_PRIVATE_KEY_PASSWORD=

KALSHI_SYNC_OPEN_MARKETS=1
KALSHI_SYNC_SERIES=1
KALSHI_MARKET_STATUS_FILTER=open
KALSHI_MAX_MARKETS=100
KALSHI_REQUEST_TIMEOUT_SECONDS=15
KALSHI_MAX_RETRIES=2

KALSHI_WS_ENABLED=0
KALSHI_WS_CHANNELS=orderbook_delta,ticker,trade,market_lifecycle_v2
KALSHI_WS_MAX_MARKETS=50
KALSHI_WS_STALE_MS=3000
KALSHI_WS_HEARTBEAT_SECONDS=15
KALSHI_WS_RECONNECT_MIN_SECONDS=1
KALSHI_WS_RECONNECT_MAX_SECONDS=60
KALSHI_WS_PERSIST_RAW=1
KALSHI_WS_SUBSCRIBE_OPEN_MARKETS=0

PAPER_ALLOW_KALSHI_REFERENCE_PRICE_FILLS=0

VENUES_ENABLED=polymarket
VENUE_METADATA_SYNC_INTERVAL_SECONDS=300
VENUE_REQUIRE_RESOLUTION_RULES=1
VENUE_MAX_SETTLEMENT_AMBIGUITY=0.35

# ===========================================================================
# Phase 7 — shadow-mode orchestration (NO live orders)
# ===========================================================================
# Shadow mode runs the full decision stack on live read-only data and records
# would-have-traded decisions. It NEVER submits/cancels real orders, NEVER uses
# a live broker, NEVER signs a Polymarket wallet tx, NEVER calls a Kalshi order
# endpoint, and NEVER subscribes to private user channels. Online research is
# OFF by default (cached only). Disabled by default.
SHADOW_ENABLED=0
SHADOW_MODE=shadow_live
SHADOW_SESSION_NAME=
SHADOW_VENUES=polymarket,kalshi
SHADOW_START_ON_BOOT=0
SHADOW_MAX_RUNTIME_MINUTES=0
SHADOW_CANDIDATE_REFRESH_MS=30000
SHADOW_RESEARCH_REFRESH_MS=300000
SHADOW_DECISION_INTERVAL_MS=5000
SHADOW_EQUITY_SNAPSHOT_MS=5000
SHADOW_READINESS_SNAPSHOT_MS=60000
SHADOW_OUTCOME_HORIZONS_MS=0,5000,30000,60000,300000,900000,3600000
SHADOW_MAX_CANDIDATES_PER_CYCLE=20
SHADOW_MAX_CANDIDATES_PER_VENUE=10

# ---- Adaptive Polymarket Market Universe Manager (selection only) ----
# Pipeline: scan 1000 -> shortlist 100 -> live-watch 80 -> trade top 20 -> hold <= 3.
# Selection/ranking only — never places, cancels, or sizes an order. Live
# order-book subscription stays gated by POLYMARKET_CLOB_ENABLED.
MARKET_SCAN_LIMIT=1000
MARKET_SHORTLIST_LIMIT=100
MARKET_LIVE_WATCHLIST_LIMIT=80
MARKET_TRADE_CANDIDATE_LIMIT=20
MAX_OPEN_POLYMARKET_TRADES=3
MAX_OPEN_TRADES_HARD_CAP=8
MIN_MARKET_LIQUIDITY_USD=1000
MIN_MARKET_VOLUME_24H_USD=500
MAX_ALLOWED_SPREAD=0.04
MIN_TOP_OF_BOOK_DEPTH_USD=100
CATALOG_REFRESH_SECONDS=600
SCORE_REFRESH_SECONDS=60
SHADOW_MAX_PROPOSALS_PER_CYCLE=5
SHADOW_MIN_LIQUIDITY_SCORE=0.25
SHADOW_MAX_SPREAD=0.05
SHADOW_MIN_TIME_TO_CLOSE_SECONDS=3600
SHADOW_REQUIRE_RESOLUTION_RULES=1
SHADOW_MAX_AMBIGUITY_SCORE=0.35
SHADOW_DEFAULT_NOTIONAL_USD=5
SHADOW_MAX_ORDER_NOTIONAL_USD=5
SHADOW_MAX_MARKET_EXPOSURE_USD=25
SHADOW_MAX_VENUE_EXPOSURE_USD=100
SHADOW_MAX_TOTAL_EXPOSURE_USD=250
SHADOW_MIN_EDGE_AFTER_COSTS=0.04
SHADOW_MAX_OPEN_ORDERS=25
SHADOW_MAX_DAILY_LOSS_USD=50
SHADOW_MAX_STALE_MS=3000
SHADOW_REQUIRE_BBO=1
SHADOW_REQUIRE_ORDERBOOK=1
SHADOW_BLOCK_ON_SEQUENCE_GAP=1
SHADOW_BLOCK_ON_TICK_SIZE_DIRTY=1
SHADOW_BLOCK_ON_VENUE_DEGRADED=1
SHADOW_USE_RESEARCH=1
SHADOW_ALLOW_ONLINE_RESEARCH=0
SHADOW_USE_CACHED_RESEARCH=1
SHADOW_MIN_EVIDENCE_SCORE=0.35
SHADOW_MIN_SOURCE_COUNT=2
SHADOW_MAX_RESEARCH_STALE_SECONDS=900
SHADOW_MIN_DECISIONS_FOR_READINESS=200
SHADOW_MIN_RUNTIME_HOURS_FOR_READINESS=24
SHADOW_REQUIRED_VENUE_UPTIME_PCT=0.98
SHADOW_MAX_STALE_BOOK_RATE=0.01
SHADOW_MAX_PARSE_ERROR_RATE=0.001
SHADOW_MAX_SEQUENCE_GAP_RATE=0.001
SHADOW_MIN_FILL_RATIO=0.25
SHADOW_MAX_REJECT_RATE=0.80
SHADOW_MIN_EDGE_CAPTURE_RATIO=0.10
SHADOW_MAX_DRAWDOWN_PCT=0.10
SHADOW_MIN_CALIBRATION_SAMPLES=30
SHADOW_MAX_BRIER_SCORE=0.25
SHADOW_MAX_LOG_LOSS=0.75
SHADOW_MAX_ECE=0.10
SHADOW_REQUIRE_RECONCILIATION_CLEAN=1
SHADOW_OUTPUT_DIR=shadow_artifacts
SHADOW_REPORT_FORMAT=json,md,csv
SHADOW_KILL_SWITCH_PATH=./SHADOW_KILL_SWITCH

# ===========================================================================
# Phase 8 — guarded-live DESIGN/DRY-RUN-ONLY skeleton (door stays shut)
# ===========================================================================
# Even with GUARDED_LIVE_ENABLED=1, real execution remains DISABLED. This only
# permits the design-only / dry-run workflow. NO real order submission, NO real
# cancellation, NO live broker, NO Polymarket wallet signing, NO Kalshi order
# placement, NO private user channels. The forbidden env vars below MUST NOT be
# set in guarded-live mode (they imply real execution and are rejected).
GUARDED_LIVE_ENABLED=0
GUARDED_LIVE_MODE=design_only
GUARDED_LIVE_DRY_RUN_ONLY=1
GUARDED_LIVE_START_ON_BOOT=0
GUARDED_LIVE_REQUIRED_SHADOW_STATUS=READY_FOR_MANUAL_REVIEW
GUARDED_LIVE_MIN_SHADOW_DECISIONS=200
GUARDED_LIVE_MIN_SHADOW_RUNTIME_HOURS=24
GUARDED_LIVE_MAX_SHADOW_REPORT_AGE_HOURS=24
GUARDED_LIVE_REQUIRED_APPROVALS=2
GUARDED_LIVE_APPROVAL_EXPIRY_MINUTES=60
GUARDED_LIVE_ARMING_EXPIRY_MINUTES=15
GUARDED_LIVE_APPROVER_ROLES=lab_manager,risk_reviewer
GUARDED_LIVE_REQUIRE_TYPED_CONFIRMATION=1
GUARDED_LIVE_ALLOW_DRY_RUN_INTENTS=1
GUARDED_LIVE_BLOCK_NETWORK=1
GUARDED_LIVE_BLOCK_SIGNING=1
GUARDED_LIVE_FORBID_ORDER_ENDPOINTS=1
GUARDED_LIVE_CONFORMANCE_REQUIRED=1
GUARDED_LIVE_MAX_ORDER_NOTIONAL_USD=1
GUARDED_LIVE_MAX_DAILY_NOTIONAL_USD=10
GUARDED_LIVE_MAX_MARKET_EXPOSURE_USD=5
GUARDED_LIVE_MAX_VENUE_EXPOSURE_USD=10
GUARDED_LIVE_MAX_TOTAL_EXPOSURE_USD=20
GUARDED_LIVE_MAX_DAILY_LOSS_USD=5
GUARDED_LIVE_MIN_EDGE_AFTER_COSTS=0.08
GUARDED_LIVE_MAX_SPREAD=0.03
GUARDED_LIVE_MAX_STALE_MS=1000
GUARDED_LIVE_MAX_AMBIGUITY_SCORE=0.25
GUARDED_LIVE_MIN_EVIDENCE_SCORE=0.50
GUARDED_LIVE_MIN_SOURCE_COUNT=2
GUARDED_LIVE_MIN_TIME_TO_CLOSE_SECONDS=3600
GUARDED_LIVE_ALLOWLIST_VENUES=
GUARDED_LIVE_ALLOWLIST_MARKETS=
GUARDED_LIVE_BLOCKLIST_MARKETS=
GUARDED_LIVE_KILL_SWITCH_PATH=./GUARDED_LIVE_KILL_SWITCH
GLOBAL_KILL_SWITCH_PATH=./KILL_SWITCH
GUARDED_LIVE_SECRET_POLICY_STRICT=1
GUARDED_LIVE_FORBIDDEN_ENV_PATTERNS=POLYMARKET_PRIVATE_KEY,POLYMARKET_WALLET_PRIVATE_KEY,POLYMARKET_SIGNER_PRIVATE_KEY,KALSHI_TRADING_PRIVATE_KEY,KALSHI_ORDER_PRIVATE_KEY,LIVE_BROKER_ENABLED,ENABLE_REAL_ORDERS,REAL_MONEY,PRODUCTION_EXECUTION
GUARDED_LIVE_OUTPUT_DIR=guarded_live_artifacts

# ---------------------------------------------------------------------------
# Phase 9: MICRO-LIVE CANARY EXECUTION.
# This is the first phase with ANY real-execution surface. It is DISABLED by
# default, demo-only by default, CLI-only, one-canary-only, FOK-only, and hard-
# capped to <= $1 in CODE (not just env). Real submission requires EVERY lock to
# be open + a typed CLI confirmation. The source-code build lock
# (MICRO_LIVE_BUILD_ENABLED) is NOT read from env in production code; it is a
# module constant that defaults False. Do NOT put real secrets in this file.
# ---------------------------------------------------------------------------
MICRO_LIVE_BUILD_ENABLED=0
MICRO_LIVE_ENABLED=0
MICRO_LIVE_ENV=demo
MICRO_LIVE_ALLOW_PRODUCTION=0
MICRO_LIVE_ACKNOWLEDGE_REAL_MONEY_RISK=
MICRO_LIVE_CLI_ONLY=1
MICRO_LIVE_ONE_ORDER_PER_TOKEN=1
MICRO_LIVE_MAX_ACTIVE_ORDERS=1
MICRO_LIVE_MAX_ORDERS_PER_DAY=1
# Hard limits (env can only make these smaller; $1 cap is enforced in code)
MICRO_LIVE_MAX_ORDER_NOTIONAL_USD=1
MICRO_LIVE_MAX_DAILY_NOTIONAL_USD=1
MICRO_LIVE_MAX_MARKET_EXPOSURE_USD=1
MICRO_LIVE_MAX_VENUE_EXPOSURE_USD=1
MICRO_LIVE_MAX_TOTAL_EXPOSURE_USD=1
MICRO_LIVE_MAX_DAILY_LOSS_USD=1
MICRO_LIVE_MIN_EDGE_AFTER_COSTS=0.10
MICRO_LIVE_MAX_SPREAD=0.02
MICRO_LIVE_MAX_STALE_MS=750
MICRO_LIVE_MAX_AMBIGUITY_SCORE=0.20
MICRO_LIVE_MIN_EVIDENCE_SCORE=0.60
MICRO_LIVE_MIN_SOURCE_COUNT=2
MICRO_LIVE_MIN_TIME_TO_CLOSE_SECONDS=7200
# Allowed execution shape (FOK / fill_or_kill only in Phase 9)
MICRO_LIVE_ALLOWED_VENUES=kalshi
MICRO_LIVE_ALLOWED_ENVIRONMENTS=demo
MICRO_LIVE_ALLOWED_ORDER_TYPES=FOK
MICRO_LIVE_ALLOWED_TIF=fill_or_kill
MICRO_LIVE_ALLOW_FAK=0
MICRO_LIVE_ALLOW_IOC=0
MICRO_LIVE_ALLOW_GTC=0
MICRO_LIVE_ALLOW_GTD=0
MICRO_LIVE_ALLOW_POST_ONLY=0
MICRO_LIVE_ALLOW_BATCH=0
MICRO_LIVE_ALLOW_REPLACE=0
MICRO_LIVE_ALLOW_AMEND=0
MICRO_LIVE_ALLOW_AUTONOMOUS_LOOP=0
# Prerequisites
MICRO_LIVE_REQUIRE_PHASE8_CONFORMANCE=1
MICRO_LIVE_REQUIRE_SHADOW_READY=1
MICRO_LIVE_REQUIRED_SHADOW_STATUS=READY_FOR_MANUAL_REVIEW
MICRO_LIVE_MAX_SHADOW_REPORT_AGE_HOURS=24
MICRO_LIVE_REQUIRE_APPROVALS=1
MICRO_LIVE_REQUIRE_ARMING_TOKEN=1
MICRO_LIVE_REQUIRE_DRY_RUN_INTENT=1
MICRO_LIVE_REQUIRE_ACCOUNT_SNAPSHOT=1
MICRO_LIVE_REQUIRE_RECONCILIATION=1
# Kill switches
MICRO_LIVE_KILL_SWITCH_PATH=./MICRO_LIVE_KILL_SWITCH
# (GUARDED_LIVE_KILL_SWITCH_PATH and GLOBAL_KILL_SWITCH_PATH reused from Phase 8)
# Kalshi trading credentials (NEVER commit real values; loaded only after locks pass)
KALSHI_MICRO_LIVE_ENABLED=0
KALSHI_MICRO_LIVE_ENV=demo
KALSHI_MICRO_LIVE_ALLOW_PROD=0
KALSHI_TRADING_ACCESS_KEY_ID=
KALSHI_TRADING_PRIVATE_KEY_PATH=
KALSHI_TRADING_PRIVATE_KEY_PEM=
KALSHI_TRADING_PRIVATE_KEY_PASSWORD=
KALSHI_MICRO_LIVE_USE_V2_ORDERS=1
KALSHI_MICRO_LIVE_DEFAULT_TIF=fill_or_kill
KALSHI_MICRO_LIVE_CANCEL_ON_PAUSE=1
KALSHI_MICRO_LIVE_SELF_TRADE_PREVENTION=taker_at_cross
KALSHI_MICRO_LIVE_SUBACCOUNT=0
# Polymarket (live signing NOT implemented in Phase 9; stays disabled)
POLYMARKET_MICRO_LIVE_ENABLED=0
POLYMARKET_MICRO_LIVE_ALLOW_PROD=0
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_PRIVATE_KEY_PATH=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_MICRO_LIVE_DEFAULT_ORDER_TYPE=FOK
POLYMARKET_MICRO_LIVE_ALLOW_FAK=0
POLYMARKET_MICRO_LIVE_ALLOW_GTC=0
POLYMARKET_MICRO_LIVE_ALLOW_GTD=0
POLYMARKET_MICRO_LIVE_HEARTBEAT_ENABLED=0
# Artifacts
MICRO_LIVE_OUTPUT_DIR=micro_live_artifacts

# ---------------------------------------------------------------------------
# Phase 10: POST-CANARY ANALYSIS & SCALING-VETO.
# Analyzes every Phase 9 canary and produces a hard recommendation. It NEVER
# scales size, NEVER enables production execution, and NEVER enables autonomous
# live trading. eligible_for_size_increase / autonomous_live are forced False in
# code. Production canary execution is unimplemented in Phase 10.
# ---------------------------------------------------------------------------
POST_CANARY_ENABLED=1
POST_CANARY_AUTO_ANALYZE_AFTER_SUBMIT=1
POST_CANARY_REQUIRE_ANALYSIS_BEFORE_NEXT_CANARY=1
POST_CANARY_OUTPUT_DIR=post_canary_artifacts
# Analysis window
POST_CANARY_MARKOUT_HORIZONS_MS=0,5000,30000,60000,300000,900000,3600000
POST_CANARY_MARKET_DATA_WINDOW_BEFORE_MS=60000
POST_CANARY_MARKET_DATA_WINDOW_AFTER_MS=3600000
POST_CANARY_ALLOW_READONLY_REFRESH=0
# Execution thresholds
POST_CANARY_MAX_ACK_LATENCY_MS=5000
POST_CANARY_MAX_RECONCILIATION_LATENCY_MS=30000
POST_CANARY_MAX_SLIPPAGE_BPS=50
POST_CANARY_MAX_FEE_DEVIATION_BPS=10
POST_CANARY_MAX_PAYLOAD_DRIFT_FIELDS=0
POST_CANARY_ALLOW_PARTIAL_FILL=0
POST_CANARY_ALLOW_UNEXPECTED_RESTING_ORDER=0
POST_CANARY_ALLOW_EMERGENCY_CANCEL_FOR_CLEAN=0
POST_CANARY_UNKNOWN_STATUS_BLOCKS=1
# Market data thresholds
POST_CANARY_MAX_BBO_AGE_MS=750
POST_CANARY_MAX_ORDERBOOK_AGE_MS=750
POST_CANARY_MAX_SPREAD=0.02
POST_CANARY_REQUIRE_SEQUENCE_CLEAN=1
POST_CANARY_REQUIRE_TICK_CLEAN=1
POST_CANARY_REQUIRE_MARKET_OPEN_AT_SUBMIT=1
# Research / risk thresholds
POST_CANARY_MAX_AMBIGUITY_SCORE=0.20
POST_CANARY_MIN_EVIDENCE_SCORE=0.60
POST_CANARY_MIN_SOURCE_COUNT=2
POST_CANARY_REQUIRE_RISK_APPROVED=1
POST_CANARY_REQUIRE_SAFETY_ALLOWED=1
POST_CANARY_REQUIRE_KILL_SWITCH_CHECK=1
# Eligibility (production = DESIGN review only; never execution)
POST_CANARY_MIN_CLEAN_DEMO_CANARIES_FOR_PROD_REVIEW=5
POST_CANARY_MIN_RENEWED_SHADOW_HOURS_AFTER_CANARY=24
POST_CANARY_MIN_RENEWED_SHADOW_DECISIONS_AFTER_CANARY=200
POST_CANARY_REQUIRE_ALL_DEMO_CANARIES_CLEAN_FOR_PROD_REVIEW=1
POST_CANARY_SIZE_INCREASE_ALLOWED=0
POST_CANARY_AUTONOMOUS_LIVE_ALLOWED=0
POST_CANARY_PRODUCTION_CANARY_IMPLEMENTED=0
# Secret / audit
POST_CANARY_SECRET_SCAN_ENABLED=1
POST_CANARY_REQUIRE_AUDIT_CHAIN=1
POST_CANARY_REQUIRE_NO_FORBIDDEN_NETWORK_CALLS=1
POST_CANARY_MAX_ADVERSE_MARKOUT_BPS=200

# ---------------------------------------------------------------------------
# Phase 11: PRODUCTION-CANARY DESIGN REVIEW (review only — NOT execution).
# Determines whether the system is ready to *design* a future production canary.
# It NEVER implements/enables production order submission, cancellation, signing,
# size increase, or autonomous live trading. The three "enable_*" flags below are
# IGNORED in code (forced off); setting them is surfaced as a critical review
# failure. Do NOT put real secrets in this file.
# ---------------------------------------------------------------------------
PRODUCTION_REVIEW_ENABLED=1
PRODUCTION_REVIEW_OUTPUT_DIR=production_review_artifacts
PRODUCTION_REVIEW_ALLOW_READONLY_ACCOUNT_SNAPSHOT=0
PRODUCTION_REVIEW_ALLOW_PRODUCTION_NETWORK=0
PRODUCTION_REVIEW_MOCK_ONLY_CONFORMANCE=1
# Evidence requirements
PRODUCTION_REVIEW_MIN_CLEAN_DEMO_CANARIES=5
PRODUCTION_REVIEW_REQUIRE_ALL_CANARIES_CLEAN=1
PRODUCTION_REVIEW_REQUIRE_NO_UNRESOLVED_CANARIES=1
PRODUCTION_REVIEW_MIN_RENEWED_SHADOW_HOURS=48
PRODUCTION_REVIEW_MIN_RENEWED_SHADOW_DECISIONS=500
PRODUCTION_REVIEW_MAX_EVIDENCE_AGE_HOURS=72
PRODUCTION_REVIEW_REQUIRE_PHASE8_CONFORMANCE=1
PRODUCTION_REVIEW_REQUIRE_PHASE9_CONFORMANCE=1
PRODUCTION_REVIEW_REQUIRE_PHASE10_ELIGIBILITY=1
# Venue/account review (manual attestations)
PRODUCTION_REVIEW_REQUIRE_JURISDICTION_ATTESTATION=1
PRODUCTION_REVIEW_REQUIRE_ACCOUNT_READINESS_ATTESTATION=1
PRODUCTION_REVIEW_REQUIRE_VENUE_TERMS_ATTESTATION=1
PRODUCTION_REVIEW_REQUIRE_PROHIBITED_MARKET_REVIEW=1
PRODUCTION_REVIEW_REQUIRE_FUNDING_ATTESTATION=1
PRODUCTION_REVIEW_REQUIRE_EXCHANGE_PERMISSION_ATTESTATION=1
# Endpoint/secret controls
PRODUCTION_REVIEW_BLOCK_ORDER_ENDPOINTS=1
PRODUCTION_REVIEW_BLOCK_CANCEL_ENDPOINTS=1
PRODUCTION_REVIEW_BLOCK_DEPOSIT_WITHDRAW_TRANSFER=1
PRODUCTION_REVIEW_BLOCK_WALLET_SIGNING=1
PRODUCTION_REVIEW_REQUIRE_READONLY_TRADING_KEY_SEPARATION=1
PRODUCTION_REVIEW_REQUIRE_SECRET_ROTATION_PLAN=1
PRODUCTION_REVIEW_REQUIRE_SECRET_REVOCATION_PLAN=1
PRODUCTION_REVIEW_SECRET_SCAN_ENABLED=1
# Operational readiness
PRODUCTION_REVIEW_REQUIRE_INCIDENT_RESPONSE_PLAN=1
PRODUCTION_REVIEW_REQUIRE_ROLLBACK_PLAN=1
PRODUCTION_REVIEW_REQUIRE_MONITORING_PLAN=1
PRODUCTION_REVIEW_REQUIRE_MANUAL_EXCHANGE_UI_CHECKLIST=1
PRODUCTION_REVIEW_REQUIRE_CHANGE_CONTROL=1
PRODUCTION_REVIEW_REQUIRED_HUMAN_REVIEWERS=2
PRODUCTION_REVIEW_APPROVAL_EXPIRY_HOURS=24
# Hard-coded Phase 11 non-execution (IGNORED in code; setting =1 fails the review)
PRODUCTION_REVIEW_ENABLE_PRODUCTION_EXECUTION=0
PRODUCTION_REVIEW_ALLOW_SIZE_INCREASE=0
PRODUCTION_REVIEW_ALLOW_AUTONOMOUS_LIVE=0
PRODUCTION_REVIEW_ALLOW_DASHBOARD_SUBMIT=0
PRODUCTION_REVIEW_ALLOW_API_SUBMIT=0

# ---- Polymarket-only PAPER training engine (engine.training; PAPER ONLY) ----
# Full-throttle PAPER training. No real orders, no Micro Live, no production,
# no live-submit, no wallet signing. Grok is research-only. Arbitrage REMOVED.
POLYMARKET_ONLY_MODE=1
HTE_AUTOTRADE=1
HTE_TRADING_UNIVERSE=polymarket
DISABLE_CRYPTO_TRADING=1
DISABLE_STOCK_TRADING=1
DISABLE_ARBITRAGE_TRADING=1
# Pipeline sizes
POLYMARKET_CLOB_ENABLED=1
POLYMARKET_USE_UNIVERSE_MANAGER=1
POLYMARKET_SCAN_LIMIT=1000
POLYMARKET_SHORTLIST_LIMIT=150
POLYMARKET_LIVE_WATCH_LIMIT=100
POLYMARKET_TRADE_CANDIDATE_LIMIT=30
POLYMARKET_MAX_OPEN_TRADES=5
POLYMARKET_MAX_OPEN_TRADES_HARD_CAP=8
POLYMARKET_MIN_NET_EDGE=0.025
POLYMARKET_BASE_UNCERTAINTY=0.01
POLYMARKET_ALLOW_OFFLINE_STUB_TRADING=0
POLYMARKET_REQUIRE_RESEARCH_OR_MODEL_EDGE=1
# Paper risk limits
PAPER_MAX_ORDER_NOTIONAL_USD=5
PAPER_MAX_MARKET_EXPOSURE_USD=20
PAPER_MAX_TOTAL_EXPOSURE_USD=100
PAPER_MAX_DAILY_LOSS_USD=50
PAPER_MAX_OPEN_ORDERS=20
PAPER_REJECT_ON_STALE_BOOK=1
PAPER_ALLOW_PM_REFERENCE_PRICE_FILLS=0
# Scan speed
POLYMARKET_SCAN_INTERVAL_SECONDS=60
POLYMARKET_METADATA_CACHE_TTL_SECONDS=60
POLYMARKET_INCREMENTAL_REFRESH=1
POLYMARKET_ASYNC_SCAN=1
POLYMARKET_MAX_CONCURRENT_REQUESTS=8
POLYMARKET_RATE_LIMIT_SLEEP_MS=100
POLYMARKET_SCAN_TIMEOUT_SECONDS=20
# Recursive feedback loop
POLYMARKET_TRAINING_FEEDBACK_INTERVAL_SECONDS=300
POLYMARKET_TRAINING_SIGNAL_MODEL=research
POLYMARKET_TRAINING_FEEDBACK_ENABLED=1
# Locked OFF (never enable for training)
MICRO_LIVE_ENABLED=0
KALSHI_MICRO_LIVE_ENABLED=0
POLYMARKET_MICRO_LIVE_ENABLED=0
GUARDED_LIVE_ENABLED=0

# ---- Chainlink oracle scanner (real READ-ONLY price feed) ----
# Chainlink is used ONLY as an input feature (probability calibration, fair value,
# confidence, market grouping, risk no-trade flags) — it never trades on its own.
# docker-compose.yml turns this ON by default and points CHAINLINK_RPC_URL at a
# public key-less Ethereum RPC, so live mainnet aggregator reads (BTC/ETH/SOL/LINK
# latestRoundData) work out of the box. Set CHAINLINK_ENABLED=0 to disable.
CHAINLINK_ENABLED=1
CHAINLINK_HISTORY_LIMIT=30
# Read-only JSON-RPC for live latestRoundData() reads (NOT a secret). The public
# default below needs no key; for higher rate limits use your own Alchemy/Infura
# mainnet URL. Leave blank to run offline / snapshot-only (replay-safe).
CHAINLINK_RPC_URL=https://ethereum-rpc.publicnode.com
# Optional JSON file overriding/extending the built-in feed registry.
CHAINLINK_REGISTRY_PATH=

# ---- Polymarket Training Engine v2 (PAPER ONLY) ----
# Mode: disabled | observe_only (evaluate+record, NO trades) | paper_train (paper trades)
POLYMARKET_TRAINING_MODE=observe_only
DISABLE_BTC_PULSE_TRADING=1
# ---- BTC 5-min Pulse PAPER-ONLY isolated training experiment (default OFF) ----
# Safe example profile: enable the PAPER-ONLY isolated pulse experiment beside
# the Polymarket campaign. It NEVER places a live order, NEVER touches a wallet,
# NEVER enables legacy BTC autotrade, and NEVER writes the Polymarket learner.
# Set BTC_PULSE_ENABLED=1 (and keep the rest of these) to unfreeze paper ticks.
BTC_PULSE_ENABLED=0
BTC_PULSE_PAPER_ONLY=1
BTC_PULSE_ISOLATED_LEARNING=1
BTC_PULSE_ALLOW_TRANSFER_LEARNING=0
BTC_PULSE_LIVE_ENABLED=0
BTC_AUTOTRADE_ENABLED=0
BTC_PULSE_TICK_SECONDS=30
BTC_PULSE_ROUND_SECONDS=300
# Probability shrink toward market (trade only TRUE edge, never price extremes)
POLYMARKET_BASE_SHRINK_FACTOR=0.25
POLYMARKET_MAX_SHRINK_FACTOR=0.60
POLYMARKET_MIN_SHRINK_FACTOR=0.05
POLYMARKET_RESEARCH_MAX_AGE_SECONDS=900
# Edge engine: trade only if net_edge > min_net_edge + uncertainty_band
POLYMARKET_MIN_NET_EDGE=0.03
POLYMARKET_MAX_SPREAD=0.08
POLYMARKET_MIN_DEPTH_AT_PRICE=50
POLYMARKET_SPREAD_PENALTY_WEIGHT=0.50
POLYMARKET_SLIPPAGE_PENALTY_WEIGHT=1.00
POLYMARKET_AMBIGUITY_PENALTY_WEIGHT=0.03
POLYMARKET_STALE_PENALTY_WEIGHT=0.02
POLYMARKET_EVIDENCE_PENALTY_WEIGHT=0.02
POLYMARKET_CALIBRATION_PENALTY_WEIGHT=0.05
POLYMARKET_LIQUIDITY_PENALTY_WEIGHT=0.03
# Sizing (Grok cannot size)
POLYMARKET_PAPER_FIXED_NOTIONAL_USD=5
POLYMARKET_USE_KELLY_FOR_SIZE=0
POLYMARKET_USE_KELLY_FOR_DIAGNOSTICS=1
POLYMARKET_KELLY_FRACTION=0.10
POLYMARKET_MAX_KELLY_SIZE_USD=5
# Scanner thresholds
POLYMARKET_MIN_VOLUME=1000
POLYMARKET_MIN_LIQUIDITY=250
POLYMARKET_MIN_TIME_TO_CLOSE_SECONDS=3600
POLYMARKET_MAX_TIME_TO_CLOSE_DAYS=90
# CLOB subscription manager
POLYMARKET_CLOB_STALE_MS=3000
POLYMARKET_SUBSCRIPTION_REFRESH_SECONDS=120
POLYMARKET_MAX_SUBSCRIPTION_CHURN_PER_REFRESH=20
# Learner / feedback
POLYMARKET_LEARNER_ENABLED=1
POLYMARKET_LEARNER_EWMA_ALPHA=0.05
POLYMARKET_MIN_BUCKET_SAMPLES=20
POLYMARKET_FEEDBACK_INTERVAL_SECONDS=300
POLYMARKET_MARKOUT_HORIZONS_SECONDS=5,30,60,300,900,3600
