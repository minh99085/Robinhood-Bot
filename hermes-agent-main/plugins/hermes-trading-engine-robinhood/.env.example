# Robinhood Agentic plugin — copy to .env and fill secrets.
# NEVER commit .env with real tokens.

# MCP endpoint (official Robinhood Trading MCP)
RH_MCP_URL=https://agent.robinhood.com/mcp/trading

# OAuth — complete login via scripts/robinhood_oauth_login.py
RH_OAUTH_REDIRECT_URI=http://127.0.0.1:53682/callback
RH_OAUTH_CLIENT_NAME=Hermes Robinhood Agent VPS

# Agentic account (optional filter; set after onboarding)
RH_AGENTIC_ACCOUNT_ID=

# Safety — live trading OFF by default
RH_LIVE_TRADING_ENABLED=0
RH_APPROVAL_MODE=review_required
RH_MAX_ORDER_NOTIONAL_USD=100
RH_REVIEW_THRESHOLD_NOTIONAL_USD=50
RH_DAILY_LOSS_LIMIT_USD=200
RH_MAX_POSITION_PCT=10
RH_MAX_SYMBOL_CONCENTRATION_PCT=25
RH_MAX_DAY_TRADES_5D=3
RH_MIN_BUYING_POWER_BUFFER_USD=50

# API publish (loopback default — safe on VPS)
RH_API_PUBLISH=127.0.0.1:8810
RH_API_PORT=8810
RH_HEALTH_INTERVAL_S=60
RH_MCP_RECONNECT_BASE_S=2
RH_MCP_RECONNECT_MAX_S=300

# --- Options loop (manual directional bias) ---
RH_OPTIONS_LOOP_ENABLED=1
RH_OPTIONS_TICK_SECONDS=120
# Comma-separated override; empty = built-in ETF+stock universe (25 symbols)
RH_OPTIONS_WATCHLIST=
# Global manual bias: call | put | none (none = scan idle until per-symbol bias set)
RH_OPTIONS_BIAS=none
# Per-symbol overrides, e.g. RH_OPTIONS_BIAS_SPY=call RH_OPTIONS_BIAS_NVDA=put
# RH_OPTIONS_BIAS_SPY=call

RH_OPTIONS_MIN_DTE=2
RH_OPTIONS_MAX_DTE=45
RH_OPTIONS_STRIKE_BAND_PCT=5
RH_OPTIONS_MAX_SPREAD_PCT=15
RH_OPTIONS_CONTRACTS=1
RH_OPTIONS_MAX_CONTRACTS=2
RH_OPTIONS_MAX_PREMIUM_USD=200
RH_OPTIONS_LONG_ONLY=1
RH_OPTIONS_MAX_OPEN_POSITIONS=5
RH_OPTIONS_SYMBOL_COOLDOWN_S=3600
RH_OPTIONS_PAPER_REVIEW=1
RH_OPTIONS_MIN_PAPER_SCANS=1

# ---------------------------------------------------------------------------
# Chart vision (secondary channel — does not replace TradingView webhooks)
# ---------------------------------------------------------------------------
CHART_VISION_ENABLED=1
# Provider: mock | openai | anthropic | google | xai
CHART_VISION_PROVIDER=mock
CHART_VISION_MODEL=
# Or set OPENAI_API_KEY / ANTHROPIC_API_KEY / GOOGLE_API_KEY / XAI_API_KEY
CHART_VISION_API_KEY=
CHART_VISION_API_BASE=
CHART_VISION_TIMEOUT_S=90

# Validation
CHART_VISION_MIN_CONFIDENCE=0.45
CHART_VISION_DOWNWEIGHT_CONFIDENCE=0.60
CHART_VISION_MAX_PRICE_REL_ERROR=0.02
CHART_VISION_REQUIRE_MCP=0

# Pipeline mode: log_only | recommendation_only | gated_execution
CHART_VISION_EXECUTION_MODE=recommendation_only
CHART_VISION_RUN_MC=1
CHART_VISION_MC_PATHS=100000
CHART_VISION_MC_HORIZON_DAYS=5
CHART_VISION_MC_SEED=42
# Path to Monte-Carlo-Sim repo (mapper + tactical engine)
MONTE_CARLO_SIM_PATH=C:\Users\tieut\Monte-Carlo-Sim
CHART_VISION_MAX_ORDER_NOTIONAL_USD=100
CHART_VISION_MAX_POSITION_PCT=10
CHART_VISION_RISK_PER_TRADE_PCT=0.5
